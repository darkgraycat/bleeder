{
	"name": "bleeder-vscode",
	"displayName": "Bleeder",
	"description": "Live music coding with Bleeder",
	"version": "0.1.0",
	"publisher": "darkgraycat",
	"engines": {
	  "vscode": "^1.80.0"
	},
	"activationEvents": [
	  "onLanguage:toml",
	  "onCommand:bleeder.play"
	],
	"main": "./extension.js",
	"contributes": {
	  "commands": [
		{"command": "bleeder.play", "title": "▶ Play"},
		{"command": "bleeder.stop", "title": "⏹ Stop"}
	  ]
	},
	"devDependencies": {
	  "@types/vscode": "^1.80.0"
	}
  }
